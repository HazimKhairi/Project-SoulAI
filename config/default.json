{
  "version": "1.0.0",
  "aiName": "SoulAI",
  "plan": "free",
  "optimization": {
    "maxAgents": 1,
    "tokenBudget": 50000,
    "contextWindow": "minimal"
  },
  "servers": {
    "skills": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/skills.sock",
      "projectRoot": "."
    },
    "superpowers": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/superpowers.sock",
      "submodulePath": "./submodules/superpowers"
    },
    "claude-code": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/claude-code.sock",
      "submodulePath": "./submodules/everything-claude-code"
    },
    "design": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/design.sock",
      "submodulePath": "./submodules/ui-ux-pro-max-skill"
    },
    "memory": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/memory.sock",
      "storagePath": "~/.soulai/memory"
    },
    "search": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/search.sock"
    },
    "verification": {
      "enabled": true,
      "socketPath": "~/.soulai/sockets/verification.sock"
    },
    "ctx7": {
      "enabled": false,
      "socketPath": "~/.soulai/sockets/ctx7.sock",
      "cliPath": "./submodules/context7/packages/cli/dist/index.js",
      "proactiveSuggestions": true,
      "autoSearch": ["react", "nextjs", "vue"],
      "subagentMode": "hybrid",
      "cacheResults": true,
      "failSafe": true,
      "maxRetries": 3,
      "timeout": 10000
    }
  },
  "features": {
    "ctx7": {
      "enabled": false,
      "proactiveSuggestions": true,
      "autoSearch": ["react", "nextjs", "vue"],
      "subagentMode": "hybrid",
      "cacheResults": true,
      "failSafe": true,
      "maxRetries": 3,
      "timeout": 10000
    }
  },
  "verification": {
    "confidenceThreshold": 0.7,
    "hallucinationThreshold": 0.3,
    "autoApproveThreshold": 0.9
  },
  "logging": {
    "level": "info",
    "file": "~/.soulai/logs/soulai.log"
  }
}
