{
  "name": "soulai",
  "version": "1.0.0",
  "description": "Open-source workflow agent for coding development",
  "type": "module",
  "main": "index.js",
  "bin": {
    "soulai": "./bin/soulai.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HazimKhairi/Project-SoulAI.git"
  },
  "bugs": {
    "url": "https://github.com/HazimKhairi/Project-SoulAI/issues"
  },
  "homepage": "https://github.com/HazimKhairi/Project-SoulAI#readme",
  "readme": "README.npm.md",
  "files": [
    "bin/",
    "config/",
    "orchestrator/",
    "scripts/",
    "index.js",
    "README.npm.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "init": "node bin/soulai.js init",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest --config vitest.integration.config.js",
    "test:e2e": "vitest --config vitest.e2e.config.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "inquirer": "^9.0.0",
    "chalk": "^5.0.0",
    "winston": "^3.11.0",
    "ajv": "^8.12.0",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["claude", "mcp", "ai", "workflow", "coding"],
  "author": "HakasAI + Hazim",
